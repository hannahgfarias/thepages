{
  "buildCommand": "npx expo export --platform web",
  "outputDirectory": "dist",
  "git": {
    "deploymentEnabled": {
      "main": true
    }
  },
  "rewrites": [
    {
      "source": "/event/:id",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": "(?i).*(bot|crawler|spider|preview|facebookexternalhit|twitterbot|slackbot|linkedinbot|whatsapp|telegrambot|discordbot|applebot).*"
        }
      ],
      "destination": "/api/event/:id"
    },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
